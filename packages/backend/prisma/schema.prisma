generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Ajouter ces champs au model User existant
// ── Enums ─────────────────────────────────────────────────────────

enum UserRole {
  admin
  member
  viewer
  @@map("user_role")
}

enum UsageType {
  personal   // Personnel
  family     // Famille
  business   // Entreprise
  @@map("usage_type")
}

enum OrgStatus {
  active
  suspended
  closed
  @@map("org_status")
}

enum OrgType {
  family
  business
  @@map("org_type")
}

enum MemberRole {
  founder    // Fondateur — un seul par organisation
  admin      // Peut gérer les membres
  member     // Membre standard
  viewer     // Lecture seule
  @@map("member_role")
}

// ── User ──────────────────────────────────────────────────────────

model User {
  id                 Int                @id @default(autoincrement())
  name               String             @db.VarChar(100)
  email              String             @unique @db.VarChar(150)
  password           String             @db.VarChar(255)

  // Devise d'affichage — changeable par l'utilisateur
  currency           String             @default("MGA") @db.VarChar(10)
  // Devise de base — fixée à l'inscription, jamais modifiable
  // Tous les montants en BDD sont dans cette devise
  defaultCurrency    String             @default("MGA") @db.VarChar(10) @map("default_currency")

  // Rôle global dans l'application
  role               UserRole           @default(member)

  // Type d'utilisation principal
  usageType          UsageType          @default(personal) @map("usage_type")

  // Plan & abonnement
  plan               String             @default("free") @db.VarChar(20)
  trialStartAt       DateTime?          @map("trial_start_at")
  trialEndAt         DateTime?          @map("trial_end_at")
  planStartAt        DateTime?          @map("plan_start_at")
  planEndAt          DateTime?          @map("plan_end_at")
  isBanned  Boolean  @default(false) @map("is_banned")

  createdAt          DateTime           @default(now()) @map("created_at")

  // Relations financières
  expenses           Expense[]
  incomes            Income[]
  budgets            Budget[]
  categories         Category[]
  recurringExpenses  RecurringExpense[]
  recurringIncomes   RecurringIncome[]
  notifications      Notification[]
  paymentRequest     PaymentRequest[]

  // Appartenance à des organisations
  memberships        OrgMember[]

  // Organisations fondées par cet utilisateur
  foundedOrgs        Organization[]     @relation("OrgFounder")

  @@map("users")
}

// ── Organisation (Famille ou Entreprise) ──────────────────────────

model Organization {
  id          Int        @id @default(autoincrement())
  name        String     @db.VarChar(150)
  type        OrgType                          // 'family' | 'business'
  status      OrgStatus  @default(active)
  currency    String     @default("MGA") @db.VarChar(10)

  // Fondateur — référence directe pour accès rapide
  founderId   Int        @map("founder_id")
  founder     User       @relation("OrgFounder", fields: [founderId], references: [id])

  description String?    @db.VarChar(500)
  logoUrl     String?    @db.VarChar(300) @map("logo_url")

  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  // Membres
  members     OrgMember[]

  @@map("organizations")
}

// ── Table pivot : membres d'une organisation ──────────────────────

model OrgMember {
  id             Int          @id @default(autoincrement())
  organizationId Int          @map("organization_id")
  userId         Int          @map("user_id")
  role           MemberRole   @default(member)
  joinedAt       DateTime     @default(now()) @map("joined_at")
  invitedBy      Int?         @map("invited_by")  // userId qui a invité

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Un utilisateur ne peut être membre qu'une seule fois par organisation
  @@unique([organizationId, userId])
  @@index([userId])
  @@index([organizationId])
  @@map("org_members")
}

model Category {
  id                Int                @id @default(autoincrement())
  userId            Int?               @map("user_id")
  name              String             @db.VarChar(100)
  icon              String?            @db.VarChar(50)
  color             String?            @db.VarChar(20)
  type              String
  user              User?              @relation(fields: [userId], references: [id], onDelete: Cascade)
  expenses          Expense[]
  incomes           Income[]
  budgets           Budget[]
  recurringExpenses RecurringExpense[]
  recurringIncomes  RecurringIncome[]  // ← nouveau

  @@map("categories")
}

model Expense {
  id                 Int               @id @default(autoincrement())
  userId             Int               @map("user_id")
  categoryId         Int?              @map("category_id")
  recurringExpenseId Int?              @map("recurring_expense_id")
  amount             Decimal           @db.Decimal(15, 2)
  description        String?
  date               DateTime          @db.Date
  isRecurring        Boolean           @default(false) @map("is_recurring")
  createdAt          DateTime          @default(now()) @map("created_at")
  user               User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  category           Category?         @relation(fields: [categoryId], references: [id])
  recurringExpense   RecurringExpense? @relation("RecurringExpense", fields: [recurringExpenseId], references: [id])

  @@index([userId, date])
  @@map("expenses")
}

model Income {
  id                Int              @id @default(autoincrement())
  userId            Int              @map("user_id")
  categoryId        Int?             @map("category_id")
  recurringIncomeId Int?             @map("recurring_income_id")
  amount            Decimal          @db.Decimal(15, 2)
  description       String?
  date              DateTime         @db.Date
  isRecurring       Boolean          @default(false) @map("is_recurring")
  createdAt         DateTime         @default(now()) @map("created_at")
  user              User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  category          Category?        @relation(fields: [categoryId], references: [id])
  recurringIncome   RecurringIncome? @relation("RecurringIncome", fields: [recurringIncomeId], references: [id])

  @@index([userId, date])
  @@map("incomes")
}

model Budget {
  id         Int       @id @default(autoincrement())
  userId     Int       @map("user_id")
  categoryId Int?      @map("category_id")
  amount     Decimal   @db.Decimal(15, 2)
  month      Int
  year       Int
  createdAt  DateTime  @default(now()) @map("created_at")
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  category   Category? @relation(fields: [categoryId], references: [id])

  @@unique([userId, categoryId, month, year])
  @@index([userId, year, month])
  @@map("budgets")
}

model RecurringExpense {
  id                Int       @id @default(autoincrement())
  userId            Int       @map("user_id")
  categoryId        Int?      @map("category_id")
  amount            Decimal   @db.Decimal(15, 2)
  description       String?
  frequency         String    // 'daily' | 'weekly' | 'monthly'
  dayOfMonth        Int?      @map("day_of_month")
  dayOfWeek         Int?      @map("day_of_week")
  dayType           String    @default("all") @map("day_type") // 'all' | 'working' | 'holiday'
  startDate         DateTime  @db.Date @map("start_date")
  endDate           DateTime? @db.Date @map("end_date")
  isActive          Boolean   @default(true) @map("is_active")
  lastRunAt         DateTime? @map("last_run_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  category          Category? @relation(fields: [categoryId], references: [id])
  generatedExpenses Expense[] @relation("RecurringExpense")

  @@index([userId, isActive])
  @@map("recurring_expenses")
}

model RecurringIncome {
  id               Int       @id @default(autoincrement())
  userId           Int       @map("user_id")
  categoryId       Int?      @map("category_id")
  amount           Decimal   @db.Decimal(15, 2)
  description      String?
  frequency        String    // 'daily' | 'weekly' | 'monthly'
  dayOfMonth       Int?      @map("day_of_month")
  dayOfWeek        Int?      @map("day_of_week")
  dayType          String    @default("all") @map("day_type")
  startDate        DateTime  @db.Date @map("start_date")
  endDate          DateTime? @db.Date @map("end_date")
  isActive         Boolean   @default(true) @map("is_active")
  lastRunAt        DateTime? @map("last_run_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  category         Category? @relation(fields: [categoryId], references: [id])
  generatedIncomes Income[]  @relation("RecurringIncome")

  @@index([userId, isActive])
  @@map("recurring_incomes")
}

model PublicHoliday {
  id          Int      @id @default(autoincrement())
  date        DateTime @db.Date @unique
  name        String   @db.VarChar(100)
  country     String   @default("MG") @db.VarChar(5)

  @@map("public_holidays")
}

// Ajouter dans schema.prisma

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  type      String   @db.VarChar(50)   // 'budget_alert' | 'income_generated' | 'recurring_generated'
  level     String   @db.VarChar(20)   // 'danger' | 'warning' | 'alert' | 'success' | 'info'
  title     String   @db.VarChar(200)
  message   String?
  data      Json?                       // payload complet (amount, pct, category...)
  isRead    Boolean  @default(false)   @map("is_read")
  dedupKey  String?  @unique @db.VarChar(200) @map("dedup_key")
  createdAt DateTime @default(now())   @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@map("notifications")
}

model PaymentRequest {
  id           Int       @id @default(autoincrement())
  userId       Int       @map("user_id")
  method       String    @db.VarChar(20)
  operator     String?   @db.VarChar(20)
  senderNumber String?   @db.VarChar(30)  @map("sender_number")
  months       Int
  amount       Decimal   @db.Decimal(15, 2)
  status       String    @default("pending") @db.VarChar(20)  // pending | approved | rejected
  justificatif String?   @db.VarChar(300)
  approvedAt   DateTime? @map("approved_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@map("payment_requests")
}